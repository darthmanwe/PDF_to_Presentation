# pdfdeck — required configuration (copy to .env and fill in)

# Anthropic Claude — vision verification, content drafting, fidelity critique
ANTHROPIC_API_KEY=

# Azure Translator — EN -> TR slide translation (optional; skip for English-only decks)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=
AZURE_TRANSLATOR_REGION=

# Optional — LangSmith tracing for agent-loop observability
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
